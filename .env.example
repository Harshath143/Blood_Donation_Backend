# App Configurations
APP_NAME="LifeDrop API"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT="development"

# Database Connection Strings
# asyncpg for async endpoints, psycopg2 sync for PostgreSQL Large Objects integration
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/lifedrop"
SYNC_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lifedrop"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# Redis Cache, Rate Limiter & PubSub
REDIS_URL="redis://localhost:6379/0"
REDIS_CACHE_TTL=300

# Security (JWT)
# 64-char random hex - generate with: openssl rand -hex 32
SECRET_KEY="357876a88cb86d49495e865f37bb34d66822c7178a994ef0a9a13b6cb591a27e"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP Email Settings
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="smtp-user@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_USE_TLS=true
FROM_EMAIL="noreply@lifedrop.in"
FROM_NAME="LifeDrop"

# Geolocation Settings
MAX_DONOR_SEARCH_RADIUS_KM=100
DEFAULT_SEARCH_RADIUS_KM=25

# OTP Expire Settings (10 minutes)
OTP_EXPIRE_SECONDS=600

# Sentry DSN
SENTRY_DSN=""
